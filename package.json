{
  "name": "bun-forge",
  "version": "0.1.0",
  "description": "Opinionated Bun project scaffolder.",
  "type": "module",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bengous/bun-forge.git"
  },
  "bugs": {
    "url": "https://github.com/bengous/bun-forge/issues"
  },
  "homepage": "https://github.com/bengous/bun-forge#readme",
  "bin": {
    "bun-forge": "./src/index.ts"
  },
  "engines": {
    "bun": ">=1.3.13"
  },
  "files": [
    "assets/brand/bun-forge-logo-full-640.png",
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "templates/**/*",
    "!templates/AGENTS.md",
    "template-sources/**/*",
    "!template-sources/AGENTS.md"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "lint": "oxlint -c .oxlintrc.jsonc --format=unix src/ scripts/ .codex/hooks/ .claude/hooks/",
    "lint:errors": "oxlint -c .oxlintrc.jsonc --quiet --format=unix src/ scripts/ .codex/hooks/ .claude/hooks/",
    "lint:arch": "dependency-cruiser --config .dependency-cruiser.cjs --output-type err src scripts .codex/hooks .claude/hooks",
    "lint:dead": "knip --include files,dependencies,unlisted,binaries --reporter compact",
    "lint:dupes": "jscpd --config .jscpd.json",
    "format": "oxfmt --write -c .oxfmtrc.jsonc 'src/**/*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,yml,yaml,toml,css,html}' 'scripts/**/*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,yml,yaml,toml,css,html}' '.claude/hooks/**/*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,yml,yaml,toml,css,html}' 'templates/**/*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,yml,yaml,toml,css,html}' 'template-sources/**/*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,yml,yaml,toml,css,html}'",
    "format:check": "oxfmt --check -c .oxfmtrc.jsonc 'src/**/*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,yml,yaml,toml,css,html}' 'scripts/**/*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,yml,yaml,toml,css,html}' '.codex/hooks/**/*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,yml,yaml,toml,css,html}' '.claude/hooks/**/*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,yml,yaml,toml,css,html}' 'templates/**/*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,yml,yaml,toml,css,html}' 'template-sources/**/*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,yml,yaml,toml,css,html}'",
    "autofix": "oxlint -c .oxlintrc.jsonc --fix src/ scripts/ .claude/hooks/ && bun run --silent format",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "bun test ./src ./scripts ./.codex/hooks ./.claude/hooks",
    "test:project-contract": "bun test src/core/project-contract.test.ts",
    "test:smoke": "bun scripts/testing/smoke.ts",
    "test:e2e-contract": "bun scripts/testing/e2e-contract.ts",
    "test:adopt-vex": "bun scripts/testing/adopt-vex.ts",
    "guard-destructive:sync": "bun scripts/sync/sync-guard-destructive.ts --write",
    "guard-destructive:check": "bun scripts/sync/sync-guard-destructive.ts --check",
    "agents:sync": "bun scripts/agents/sync-agents-md.ts --write",
    "agents:check": "bun scripts/agents/sync-agents-md.ts --check",
    "lint:audit": "bun scripts/quality/audit-oxlint-rules.ts",
    "check:links": "bun scripts/quality/check-links-local.ts",
    "repo:bootstrap": "bun scripts/setup/bootstrap-git-config.ts",
    "repo:prepare": "bun scripts/setup/bootstrap-prepare.ts",
    "validate": "bun scripts/validation/validate.ts",
    "validate:scale": "bun run --silent validate && bun run --silent lint:dead && bun run --silent lint:dupes && bun run --silent check:links && bun run --silent test:e2e-contract && bun run --silent test:smoke"
  },
  "dependencies": {
    "@clack/prompts": "1.3.0",
    "commander": "14.0.3"
  },
  "devDependencies": {
    "@types/bun": "1.3.13",
    "dependency-cruiser": "17.4.0",
    "jscpd": "4.0.9",
    "knip": "6.12.0",
    "lefthook": "2.1.6",
    "oxfmt": "0.48.0",
    "oxlint": "1.63.0",
    "oxlint-plugin-complexity": "2.1.2",
    "oxlint-tsgolint": "0.22.1",
    "typescript": "6.0.3"
  },
  "license": "MIT"
}
