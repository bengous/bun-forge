{
  "name": "kitsmith",
  "version": "0.3.1",
  "description": "Bun-first project generator for TypeScript repos with AI-agent guardrails.",
  "type": "module",
  "private": false,
  "keywords": [
    "bun",
    "scaffolder",
    "project-generator",
    "typescript",
    "cli",
    "starter",
    "template",
    "ai-agents"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bengous/kitsmith.git"
  },
  "bugs": {
    "url": "https://github.com/bengous/kitsmith/issues"
  },
  "homepage": "https://github.com/bengous/kitsmith#readme",
  "bin": {
    "kitsmith": "dist/index.js"
  },
  "engines": {
    "bun": ">=1.3.13"
  },
  "packageManager": "bun@1.3.13",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "assets/brand/kitsmith-logo-full-640.png",
    "templates/**/*",
    "!templates/AGENTS.md",
    "template-sources/**/*",
    "!template-sources/AGENTS.md"
  ],
  "scripts": {
    "build": "bun scripts/build-package.ts",
    "prepack": "bun run build",
    "dev": "bun run src/index.ts",
    "lint": "oxlint -c .oxlintrc.jsonc --format=unix src/ scripts/ .codex/hooks/ .claude/hooks/",
    "lint:errors": "oxlint -c .oxlintrc.jsonc --quiet --format=unix src/ scripts/ .codex/hooks/ .claude/hooks/",
    "lint:arch": "dependency-cruiser --config .dependency-cruiser.cjs --output-type err src scripts .codex/hooks .claude/hooks",
    "lint:dead": "knip --include files,dependencies,unlisted,binaries --reporter compact",
    "lint:dupes": "jscpd --config .jscpd.json",
    "format": "oxfmt --write -c .oxfmtrc.jsonc 'commitlint.config.js' 'src/**/*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,yml,yaml,toml,css,html}' 'scripts/**/*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,yml,yaml,toml,css,html}' '.claude/hooks/**/*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,yml,yaml,toml,css,html}' 'templates/**/*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,yml,yaml,toml,css,html}' 'template-sources/**/*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,yml,yaml,toml,css,html}'",
    "format:check": "oxfmt --check -c .oxfmtrc.jsonc 'commitlint.config.js' 'src/**/*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,yml,yaml,toml,css,html}' 'scripts/**/*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,yml,yaml,toml,css,html}' '.codex/hooks/**/*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,yml,yaml,toml,css,html}' '.claude/hooks/**/*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,yml,yaml,toml,css,html}' 'templates/**/*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,yml,yaml,toml,css,html}' 'template-sources/**/*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,yml,yaml,toml,css,html}'",
    "autofix": "bun scripts/validation/autofix.ts",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "bun test ./src ./scripts ./.codex/hooks ./.claude/hooks",
    "test:project-contract": "bun test src/core/project-contract.test.ts",
    "test:smoke": "bun scripts/testing/smoke.ts",
    "test:safe-install": "bun scripts/testing/safe-install-smoke.ts",
    "test:e2e-contract": "bun scripts/testing/e2e-contract.ts",
    "test:adopt-vex": "bun scripts/testing/adopt-vex.ts",
    "guard-destructive:sync": "bun scripts/sync/sync-guard-destructive.ts --write",
    "guard-destructive:check": "bun scripts/sync/sync-guard-destructive.ts --check",
    "agents:sync": "bun scripts/agents/sync-agents-md.ts --write",
    "agents:check": "bun scripts/agents/sync-agents-md.ts --check",
    "lint:audit": "bun scripts/quality/audit-oxlint-rules.ts",
    "check:links": "bun scripts/quality/check-links-local.ts",
    "release:prepare": "bun scripts/release/prepare.ts",
    "repo:bootstrap": "bun scripts/setup/bootstrap-git-config.ts",
    "repo:prepare": "bun scripts/setup/bootstrap-prepare.ts",
    "check": "bun scripts/validation/validate.ts --plan check",
    "validate": "bun scripts/validation/validate.ts",
    "validate:deep": "bun scripts/validation/validate.ts --plan deep",
    "validate:generated": "bun scripts/validation/validate.ts --plan generated",
    "validate:sandbox": "bun scripts/validation/validate.ts --plan sandbox"
  },
  "dependencies": {
    "@clack/prompts": "1.4.0",
    "commander": "14.0.3"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@types/bun": "1.3.13",
    "dependency-cruiser": "17.4.0",
    "jscpd": "4.1.1",
    "knip": "6.13.1",
    "lefthook": "2.1.6",
    "oxfmt": "0.49.0",
    "oxlint": "1.64.0",
    "oxlint-plugin-complexity": "2.1.2",
    "oxlint-tsgolint": "0.22.1",
    "typescript": "6.0.3"
  },
  "license": "MIT"
}
