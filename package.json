{
  "name": "bun-forge",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "bin": {
    "bun-forge": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "lint": "oxlint -c .oxlintrc.jsonc --format=unix src/ scripts/",
    "lint:errors": "oxlint -c .oxlintrc.jsonc --quiet --format=unix src/ scripts/",
    "lint:arch": "dependency-cruiser --config .dependency-cruiser.cjs --output-type err src scripts",
    "lint:dead": "knip --include files,dependencies,unlisted,binaries --reporter compact",
    "lint:dupes": "jscpd --config .jscpd.json",
    "format": "oxfmt --write -c .oxfmtrc.jsonc src/ scripts/",
    "format:check": "oxfmt --check -c .oxfmtrc.jsonc src/ scripts/",
    "autofix": "oxlint -c .oxlintrc.jsonc --fix src/ scripts/ && oxfmt --write -c .oxfmtrc.jsonc src/ scripts/",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "bun test",
    "test:smoke": "bun scripts/testing/smoke.ts",
    "test:e2e-contract": "bun scripts/testing/e2e-contract.ts",
    "agents:sync": "bun scripts/agents/sync-agents-md.ts --write",
    "agents:check": "bun scripts/agents/sync-agents-md.ts --check",
    "lint:audit": "bun scripts/quality/audit-oxlint-rules.ts",
    "check:links": "bun scripts/quality/check-links-local.ts",
    "repo:bootstrap": "bun scripts/setup/bootstrap-git-config.ts",
    "prepare": "bun scripts/setup/bootstrap-prepare.ts",
    "validate": "bun scripts/validation/validate.ts",
    "validate:scale": "bun run --silent validate && bun run --silent lint:dead && bun run --silent lint:dupes && bun run --silent check:links && bun run --silent test:e2e-contract && bun run --silent test:smoke"
  },
  "dependencies": {
    "@clack/prompts": "0.11.0",
    "commander": "14.0.3"
  },
  "devDependencies": {
    "@types/bun": "1.3.12",
    "dependency-cruiser": "17.3.10",
    "jscpd": "4.0.9",
    "knip": "6.1.1",
    "lefthook": "2.1.6",
    "oxfmt": "0.45.0",
    "oxlint": "1.60.0",
    "oxlint-plugin-complexity": "2.1.1",
    "oxlint-tsgolint": "0.21.1",
    "typescript": "6.0.3"
  }
}
